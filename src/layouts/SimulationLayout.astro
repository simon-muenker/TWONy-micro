---
import "@styles/global.css";

import MobileTopBar from "@layouts/partials/MobileTopBar.astro";
import Flyout from "@layouts/partials/Flyout.astro";
import FlyoutController from "@layouts/partials/FlyoutController.astro";
import Sidebar from "@layouts/partials/Sidebar.astro";
import Branding from "@layouts/partials/Branding.astro";
import Menu from "@layouts/partials/Menu.astro";
import Footer from "@layouts/partials/Footer.astro";
import Evaluation from "@pages/partials/Evaluation.svelte";

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <MobileTopBar navFlyoutId="nav" rightFlyoutId="eval" rightIcon="mdi:chart-bar" rightHideClass="xl:invisible" />

    <Flyout id="nav" side="left" hideOn="lg:hidden" padding="p-6" gap="gap-8">
      <header slot="header"><Branding /></header>
      <div class="rounded-xl bg-sky-50 px-3 py-3"><Menu /></div>
      <Footer />
    </Flyout>

    <Flyout id="eval" side="right" hideOn="xl:hidden" padding="p-4" gap="gap-4">
      <span slot="header" class="text-base font-semibold text-slate-700">Evaluation</span>
      <Evaluation client:load />
    </Flyout>

    <FlyoutController />

    <div class="mx-auto max-w-screen-2xl px-6 py-16 md:px-8">
      <div class="grid grid-cols-12 gap-0 lg:gap-16">
        <div class="relative col-span-3 hidden lg:block">
          <Sidebar />
        </div>

        <main class="col-span-12 lg:col-span-9 xl:col-span-6">
          <slot />
        </main>

        <aside class="col-span-3 hidden xl:block">
          <Evaluation client:load />
        </aside>
      </div>
    </div>
  </body>
</html>
